<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TRM_Line_Item_Category__c</fullName>
    <description>Auto-calculated formula. Prescription if code is exactly 11 numeric digits (NDC format), otherwise Medical.</description>
    <externalId>false</externalId>
    <formula>IF(
  AND(
    NOT(ISBLANK(CPT_HCPCS_NDC__c)),
    LEN(CPT_HCPCS_NDC__c) = 11,
    ISNUMBER(CPT_HCPCS_NDC__c)
  ),
  &quot;Prescription&quot;,
  &quot;Medical&quot;
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Line Item Category</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
